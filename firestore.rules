rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.uid in ["u5SeqT54FcNocFcXjiRcKowjHqC2", "GH3gfM33f5b1GW12hccshSBBtez2", "J4AQs5wSpaWsSjtj04JLqCHPIeg1"] ||
        request.auth.token.email in ["nazirczarkes@gmail.com", "yourimaginationstudio@gmail.com"]
      );
    }

    match /counters/{document=**} {
      allow read, write: if true;
    }

    match /radio_stats/{document=**} {
      allow read, write: if true;
    }

    match /live_presence/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/favorites/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /public_chat/{id} {
      allow read, create: if request.auth != null;
    }

    match /prayer_intentions/{id} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /christianInspirations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /christianInspirations/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /christianInspirations/{postId}/favorites/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /morning_inspirations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /morning_inspirations/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /morning_inspirations/{postId}/favorites/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

